{
    "name": "badrsh/filament-ai-translate",
    "description": "AI-powered field translation for Filament forms. Auto-populate translations using OpenAI, DeepL, or any custom AI translator.",
    "keywords": [
        "laravel",
        "filament",
        "translate",
        "translation",
        "ai",
        "openai",
        "multilingual",
        "i18n",
        "filament-plugin"
    ],
    "homepage": "https://github.com/badrsh/filament-ai-translate",
    "license": "MIT",
    "authors": [
        {
            "name": "Badrsh",
            "email": "badrsh@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "filament/filament": "^3.0|^4.0|^5.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "files": [
            "src/Support/FilamentCompat.php"
        ],
        "psr-4": {
            "Badrsh\\FilamentAiTranslate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Badrsh\\FilamentAiTranslate\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Badrsh\\FilamentAiTranslate\\FilamentAiTranslateServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
