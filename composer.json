{
    "name": "molham/filament-translate-field",
    "description": "AI-powered field translation for Filament forms. Translate content between languages with OpenAI, DeepL, or any custom translator.",
    "keywords": [
        "laravel",
        "filament",
        "translate",
        "translation",
        "ai",
        "openai",
        "multilingual",
        "i18n",
        "filament-plugin"
    ],
    "homepage": "https://github.com/molham/filament-translate-field",
    "license": "MIT",
    "authors": [
        {
            "name": "Molham Team",
            "email": "dev@molhamteam.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "filament/filament": "^3.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Molham\\FilamentTranslateField\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Molham\\FilamentTranslateField\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Molham\\FilamentTranslateField\\FilamentTranslateFieldServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
